DISCORD_TOKEN=your_real_token_here
ORDER_CHANNEL_ID=your_channel_id_here
GUILD_ID=your_guild_id_here
# DATA_PATH=./data.json  (default; file is created automatically on first run)

# --- Mythic Shop alerts ---
# Channel where the bot pings people when a watched skin is in the shop.
# If unset, the bot DMs each subscriber instead.
MYTHIC_ALERT_CHANNEL_ID=your_alert_channel_id_here
# How often to check the shop, in minutes (default 30).
# MYTHIC_POLL_MINUTES=30